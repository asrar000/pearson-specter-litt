# ── Required ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Storage paths (defaults work out of the box) ──────────
CHROMA_DB_PATH=./data/chroma
SQLITE_DB_PATH=./data/psl.db
UPLOAD_DIR=./data/uploads

# ── Tesseract binary (override if not in PATH) ────────────
# TESSERACT_CMD=/usr/bin/tesseract

# ── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────
TOP_K=6

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
