# ── Required for LLM draft generation ─────────────────────
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional key pool for auto-rotation on rate-limit/auth/transient errors.
# The primary GROQ_API_KEY is automatically included; add extra keys here.
# Example with 4 keys:
# GROQ_API_KEYS=gsk_key_2,gsk_key_3,gsk_key_4
GROQ_API_KEYS=

# Main model
GROQ_MODEL=llama-3.3-70b-versatile

# Optional fallback models, comma-separated. Tried after the main model fails.
GROQ_MODEL_FALLBACKS=llama-3.1-8b-instant

# Retry/key-rotation tuning
GROQ_RETRY_PER_MODEL=1
GROQ_RETRY_BACKOFF_BASE_SEC=3
GROQ_RETRY_BACKOFF_MAX_SEC=45

# Output/call tuning
GROQ_MAX_TOKENS=420
GROQ_TIMEOUT_SECONDS=45
GROQ_TEMPERATURE=0.0

# ── Storage paths (defaults work out of the box) ──────────
CHROMA_DB_PATH=./data/chroma
SQLITE_DB_PATH=./data/psl.db
UPLOAD_DIR=./data/uploads

# ── Tesseract binary (override if not in PATH) ────────────
# TESSERACT_CMD=/usr/bin/tesseract

# ── Chunking ──────────────────────────────────────────────
CHUNK_SIZE=400
CHUNK_OVERLAP=80

# ── Retrieval ─────────────────────────────────────────────
TOP_K=6

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
